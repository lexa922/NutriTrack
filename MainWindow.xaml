<Window x:Class="NutriTrack.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NutriTrack"
        mc:Ignorable="d"
        Title="NutriTrack - Трекер Калорій" Height="500" Width="800"
        Background="#F5F5F5">
    <Grid Margin="20">
<Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <!-- ЛІВА ЧАСТИНА: Список спожитої їжі -->
        <StackPanel Grid.Column="0" Margin="0,0,10,0">
            <TextBlock Text="Сьогоднішній журнал" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
            
            <!-- Статистика калорій -->
            <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <StackPanel Orientation="Horizontal">
                    <StackPanel Margin="0,0,30,0">
                        <TextBlock Text="Ціль" Foreground="Gray"/>
                        <TextBlock Text="{Binding DailyGoal, StringFormat='{}{0} ккал'}" FontSize="18" FontWeight="Medium"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Спожито" Foreground="Gray"/>
                        <!-- Виправив тут: просто прив'язка без псевдокоду -->
                        <TextBlock Text="{Binding CurrentCalories, StringFormat='{}{0} ккал'}" FontSize="18" FontWeight="Medium" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <ListBox ItemsSource="{Binding TodayLogs}" Height="300" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="5" Margin="0,2" Padding="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Product.Name}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding ServingSizeGrams, StringFormat='{}{0} г'}" FontSize="12" Foreground="Gray"/>
                                </StackPanel>
                                <!-- Виправив тут: Foreground замість Color -->
                                <TextBlock Grid.Column="1" Text="{Binding TotalCalories, StringFormat='{}{0} ккал'}" 
                                           VerticalAlignment="Center" FontWeight="Bold" Foreground="Green"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>

        <!-- ПРАВА ЧАСТИНА: Форма додавання -->
        <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="15" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Додати їжу" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                
                <TextBlock Text="Продукт:" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding AvailableProducts}" 
                          SelectedItem="{Binding SelectedProduct}"
                          DisplayMemberPath="Name" Margin="0,0,0,15"/>

                <TextBlock Text="Вага (г):" Margin="0,0,0,5"/>
                <TextBox Text="{Binding InputWeight, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20" Padding="5"/>

                <Button Content="Додати в щоденник" 
                        Command="{Binding AddFoodCommand}"
                        Background="#4CAF50" Foreground="White" FontWeight="Bold" Padding="10" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
