<Window x:Class="NutriTrack.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:NutriTrack.Views"
        mc:Ignorable="d"
        Title="NutriTrack - Реєстрація" Height="650" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Grid>
        <Border Background="White" CornerRadius="15" Padding="25" Margin="20" VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="270" Opacity="0.1" ShadowDepth="2"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Створення акаунту" FontSize="24" FontWeight="Bold" Foreground="#4CAF50" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    
                    <UniformGrid Columns="2">
                        <StackPanel Margin="5">
                            <TextBlock Text="Логін" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Padding="8"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <TextBlock Text="Пароль" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Padding="8"/>
                        </StackPanel>
                    </UniformGrid>

                    <StackPanel Margin="5,10,5,5">
                        <TextBlock Text="Ім'я" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Padding="8"/>
                    </StackPanel>
                    
                    <UniformGrid Columns="3" Margin="0,10,0,0">
                        <StackPanel Margin="5">
                            <TextBlock Text="Вік" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding Age, UpdateSourceTrigger=PropertyChanged}" Padding="8"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <TextBlock Text="Вага (кг)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding Weight, UpdateSourceTrigger=PropertyChanged}" Padding="8"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <TextBlock Text="Зріст (см)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}" Padding="8"/>
                        </StackPanel>
                    </UniformGrid>
                    
                    <StackPanel Margin="5,15,5,5">
                        <TextBlock Text="Стать" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding Genders}" SelectedItem="{Binding SelectedGender}" Padding="8"/>
                    </StackPanel>

                    <StackPanel Margin="5,10,5,20">
                        <TextBlock Text="Рівень активності" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding ActivityLevels}" SelectedItem="{Binding SelectedActivity}" Padding="8"/>
                    </StackPanel>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" HorizontalAlignment="Center" Margin="0,0,0,10" TextWrapping="Wrap"/>

                    <Button Content="Зареєструватися" Command="{Binding RegisterCommand}" 
                            Background="#4CAF50" Foreground="White" FontWeight="Bold" Padding="12" BorderThickness="0" Cursor="Hand" Margin="0,0,0,10">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="Вже є акаунт? Увійти" Command="{Binding BackToLoginCommand}"
                            Background="Transparent" Foreground="#2196F3" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
