<Window x:Class="NutriTrack.Views.AddProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:NutriTrack.Views"
        mc:Ignorable="d"
        Title="Додати продукт" Height="450" Width="350"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Border Padding="20" Background="#F5F5F5">
        <StackPanel>
            <TextBlock Text="Новий продукт" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

            <TextBlock Text="Назва:" Margin="0,0,0,3"/>
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Padding="5"/>

            <UniformGrid Columns="2">
                <StackPanel Margin="0,0,5,10">
                    <TextBlock Text="Ккал (100г):" FontSize="11"/>
                    <TextBox Text="{Binding Calories, UpdateSourceTrigger=LostFocus}" Padding="5"/>
                </StackPanel>
                <StackPanel Margin="5,0,0,10">
                    <TextBlock Text="Білки:" FontSize="11"/>
                    <TextBox Text="{Binding Proteins, UpdateSourceTrigger=LostFocus}" Padding="5"/>
                </StackPanel>
                <StackPanel Margin="0,0,5,10">
                    <TextBlock Text="Жири:" FontSize="11"/>
                    <TextBox Text="{Binding Fats, UpdateSourceTrigger=LostFocus}" Padding="5"/>
                </StackPanel>
                <StackPanel Margin="5,0,0,10">
                    <TextBlock Text="Вуглеводи:" FontSize="11"/>
                    <TextBox Text="{Binding Carbs, UpdateSourceTrigger=LostFocus}" Padding="5"/>
                </StackPanel>
            </UniformGrid>
            <TextBlock Text="Категорія:" Margin="0,10,0,3" FontWeight="SemiBold"/>
            <ComboBox ItemsSource="{Binding Categories}" 
                      SelectedItem="{Binding SelectedCategory}" 
                      Padding="5" Margin="0,0,0,10"/>

            <Button Content="Зберегти" Command="{Binding SaveCommand}" 
                    Background="#4CAF50" Foreground="White" FontWeight="Bold" 
                    Padding="10" Margin="0,15,0,0"/>
        </StackPanel>
    </Border>
</Window>
